page {
  min-height: 100%;
  background-color: #efe7d8;
  background-image:
    linear-gradient(180deg, rgba(255, 252, 245, 0.68), rgba(235, 224, 206, 0.76)),
    linear-gradient(90deg, rgba(132, 111, 80, 0.05) 1rpx, transparent 1rpx);
  background-size: auto, 36rpx 36rpx;
  color: #24261f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  padding: 28rpx 22rpx 56rpx;
}

.panel {
  padding: 30rpx 28rpx 32rpx;
  border-radius: 26rpx;
  background-color: rgba(255, 252, 246, 0.96);
  background-image:
    linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(247, 240, 229, 0.26)),
    linear-gradient(90deg, rgba(151, 129, 96, 0.07), rgba(151, 129, 96, 0) 18rpx);
  background-size: auto, 100% 32rpx;
  border: 1rpx solid rgba(112, 94, 68, 0.18);
  box-shadow:
    0 18rpx 46rpx rgba(71, 56, 37, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(134, 113, 83, 0.16);
}

.top-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eyebrow {
  font-size: 22rpx;
  letter-spacing: 0;
  text-transform: uppercase;
  color: #836f55;
}

.kicker {
  font-size: 24rpx;
  color: #736856;
}

.top-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.pill-link,
.badge,
.nav-rail-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.pill-link,
.badge {
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #fbf5e9, #ede2cf);
  border: 1rpx solid rgba(126, 104, 76, 0.18);
  color: #475146;
  font-size: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.title {
  display: block;
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 700;
  letter-spacing: 0;
  color: #24261f;
}

.title-accent {
  display: block;
  margin-top: 10rpx;
  color: #31453a;
}

.body {
  font-size: 28rpx;
  line-height: 1.66;
  color: #5d5c53;
}

.feedback-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #4d5049;
  font-size: 28rpx;
  line-height: 1.55;
}

.flow-page-stack {
  gap: 18rpx;
}

.flow-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 6rpx 2rpx 4rpx;
}

.flow-hero--center {
  align-items: center;
  text-align: center;
}

.flow-title {
  display: block;
  color: #1f241f;
  font-size: 46rpx;
  font-weight: 720;
  line-height: 1.18;
}

.flow-copy {
  color: #57564f;
  font-size: 25rpx;
  line-height: 1.58;
}

.flow-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.82);
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.flow-card .button-group {
  margin-top: 0;
}

.flow-action-row {
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.flow-action-row .button-primary,
.flow-action-row .button-secondary {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  text-align: center;
  line-height: 1.35;
}

.flow-timer-card {
  width: 100%;
  min-height: 296rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(46, 61, 50, 0.18);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(235, 226, 209, 0.88));
  box-shadow:
    0 18rpx 36rpx rgba(61, 50, 34, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.timer--steady {
  font-size: 118rpx;
}

.flow-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.flow-list-item,
.flow-list-button {
  width: 100%;
  min-height: 82rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  background: rgba(255, 253, 248, 0.86);
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.flow-list-mark {
  flex-shrink: 0;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.1);
  color: #3d4e42;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
}

.flow-list-title {
  flex: 1;
  min-width: 0;
  color: #252b25;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.42;
  text-align: left;
}

.muted {
  color: #827767;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 22rpx 22rpx 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(246, 239, 228, 0.92));
  border: 1rpx solid rgba(116, 96, 69, 0.15);
  box-shadow:
    0 8rpx 18rpx rgba(85, 69, 50, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  overflow: hidden;
}

.card--interactive:active {
  transform: translateY(2rpx);
}

.card--selected {
  border-color: rgba(84, 105, 86, 0.28);
  background: linear-gradient(180deg, #fbf8ef, #eef1e5);
  box-shadow:
    0 10rpx 24rpx rgba(72, 83, 69, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.card-badge {
  font-size: 22rpx;
  letter-spacing: 0;
  color: #816d52;
}

.card-title {
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 650;
  color: #24261f;
}

.card-desc {
  font-size: 26rpx;
  line-height: 1.58;
  color: #636057;
}

.card-count {
  display: inline-block;
  margin-top: 4rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.08);
  color: #4a5f53;
  font-size: 22rpx;
}

.card--grid {
  width: 100%;
  min-height: 184rpx;
  padding: 22rpx 16rpx;
  gap: 10rpx;
  box-sizing: border-box;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.card--grid .card-title {
  font-size: 30rpx;
  line-height: 1.34;
}

.card--grid .card-desc {
  max-width: 220rpx;
  font-size: 22rpx;
  line-height: 1.58;
  color: #625f57;
}

.state-card-head,
.stats-state-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.state-card-emoji {
  display: block;
  font-size: 34rpx;
  line-height: 1;
}

.state-card-name {
  color: #24261f;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.3;
  text-align: center;
}

.summary {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(245, 240, 229, 0.98), rgba(237, 231, 218, 0.92));
  border: 1rpx solid rgba(106, 90, 67, 0.14);
  box-shadow: inset 8rpx 0 0 rgba(50, 70, 58, 0.12);
}

.summary-label {
  font-size: 22rpx;
  letter-spacing: 0;
  text-transform: uppercase;
  color: #776a58;
}

.summary-value {
  font-size: 31rpx;
  line-height: 1.62;
  font-weight: 600;
  color: #202520;
}

.summary--quiet {
  box-shadow: inset 6rpx 0 0 rgba(50, 70, 58, 0.1);
}

.feedback-axis-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(89, 74, 53, 0.16);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(239, 231, 216, 0.9));
  box-shadow: inset 8rpx 0 0 rgba(50, 70, 58, 0.12);
}

.feedback-axis-panel--month {
  background: linear-gradient(180deg, rgba(250, 246, 236, 0.94), rgba(235, 226, 210, 0.88));
  box-shadow: inset 8rpx 0 0 rgba(122, 96, 58, 0.1);
}

.feedback-axis-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feedback-axis-link {
  flex-shrink: 0;
  color: #4e5f51;
  font-size: 23rpx;
  font-weight: 650;
}

.feedback-axis-main {
  color: #202520;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.5;
}

.feedback-axis-empty {
  color: #766c5c;
  font-size: 25rpx;
  line-height: 1.55;
}

.feedback-month-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feedback-month-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.feedback-month-index {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.1);
  color: #3d4e42;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
}

.feedback-month-task {
  flex: 1;
  min-width: 0;
  color: #343932;
  font-size: 25rpx;
  line-height: 1.45;
}

.input-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  letter-spacing: 0;
  color: #625947;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(108, 92, 70, 0.2);
  background: rgba(255, 253, 249, 0.96);
  box-sizing: border-box;
  box-shadow: inset 0 2rpx 10rpx rgba(120, 104, 82, 0.05);
  font-size: 28rpx;
  line-height: 1.66;
  color: #1f241f;
}

.textarea--compact {
  min-height: 132rpx;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 28rpx;
}

.button-group--split {
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;
  gap: 14rpx;
}

.button-group--axis {
  margin-top: 0;
}

.button-primary,
.button-secondary,
.button-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 650;
}

.button-primary {
  background: linear-gradient(180deg, #304438, #233128);
  border: 1rpx solid rgba(18, 29, 22, 0.26);
  color: #fbf7ef;
  box-shadow:
    0 14rpx 26rpx rgba(29, 40, 33, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.button-primary[disabled] {
  background: rgba(255, 253, 248, 0.82);
  border-color: rgba(48, 68, 56, 0.3);
  color: #34483b;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 8rpx 18rpx rgba(57, 48, 34, 0.06);
}

.button-secondary {
  background: linear-gradient(180deg, #f6efe2, #eadfcb);
  border: 1rpx solid rgba(116, 95, 69, 0.18);
  color: #2f3f35;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.button-secondary--panel {
  width: calc(50% - 7rpx);
  min-height: 114rpx;
  align-items: flex-start;
  justify-content: center;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 18rpx 16rpx;
}

.button-ghost {
  min-height: 68rpx;
  justify-content: flex-start;
  padding: 0;
  border-radius: 0;
  color: #5a655d;
  font-size: 25rpx;
  font-weight: 500;
  background: transparent;
}

.courage-action-group {
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;
  gap: 14rpx;
}

.courage-action-button {
  flex: 1;
  min-width: 0;
  min-height: 108rpx;
  padding: 0 18rpx;
  text-align: center;
  line-height: 1.35;
}

.button-panel-title {
  font-size: 30rpx;
  font-weight: 650;
  color: #27362e;
}

.button-panel-meta {
  font-size: 22rpx;
  color: #716654;
}

.micro-copy {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #736a5b;
}

.drag-check-stack {
  gap: 28rpx;
}

.drag-check-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 10rpx 0 2rpx;
  text-align: center;
}

.drag-check-title {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 16rpx;
  color: #1f241f;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.16;
}

.drag-check-title-accent {
  color: #31453a;
}

.drag-check-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #4d5049;
  font-size: 27rpx;
  line-height: 1.55;
}

.drag-choice-row {
  display: flex;
  gap: 14rpx;
}

.drag-choice-card {
  flex: 1;
  min-width: 0;
  min-height: 178rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 14rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(242, 235, 221, 0.9));
  border: 1rpx solid rgba(103, 87, 64, 0.16);
  box-sizing: border-box;
  box-shadow:
    0 10rpx 22rpx rgba(73, 57, 38, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
  text-align: center;
}

.drag-choice-card--selected {
  background: linear-gradient(180deg, #f4f1e6, #e4eadc);
  border-color: rgba(54, 81, 67, 0.34);
  box-shadow:
    0 14rpx 28rpx rgba(58, 70, 59, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.drag-choice-title {
  color: #202520;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.drag-choice-desc {
  color: #625f57;
  font-size: 23rpx;
  line-height: 1.45;
}

.timer-wrap {
  align-items: center;
  text-align: center;
  gap: 26rpx;
}

.timer {
  font-size: 176rpx;
  line-height: 1;
  font-weight: 720;
  color: #202520;
}

.feedback-timer-card {
  width: 100%;
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx;
  border: 1rpx solid rgba(46, 61, 50, 0.22);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(231, 222, 204, 0.86));
  box-shadow:
    0 24rpx 54rpx rgba(61, 50, 34, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88),
    inset 0 -14rpx 28rpx rgba(62, 49, 33, 0.06);
}

.feedback-timer-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 14rpx;
}

.feedback-timer-unit {
  color: #5c6259;
  font-size: 42rpx;
  font-weight: 650;
}

.timer-subtitle {
  font-size: 28rpx;
  letter-spacing: 0;
  color: #5c6259;
}

.progress-track {
  width: 100%;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(71, 90, 78, 0.12);
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #7d8f76, #2d4034);
}

.choice-list,
.list-rows {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.escaped-page-stack {
  gap: 18rpx;
}

.escaped-home-hero {
  gap: 8rpx;
}

.escaped-state-grid {
  gap: 14rpx;
}

.escaped-state-card {
  min-height: 176rpx;
}

.escaped-return-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 16rpx 16rpx 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(75, 91, 70, 0.18);
  background: rgba(247, 241, 227, 0.82);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}

.escaped-return-texts {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.escaped-return-copy {
  color: #5a554c;
  font-size: 25rpx;
  line-height: 1.42;
  font-weight: 600;
}

.escaped-return-button {
  flex-shrink: 0;
  min-width: 156rpx;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #3f5145, #27372e);
  color: #fbf7ef;
  font-size: 24rpx;
  font-weight: 650;
  box-shadow: 0 10rpx 20rpx rgba(42, 57, 47, 0.18);
}

.emotion-continue-button {
  margin-top: 0;
}

.emotion-calm-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.emotion-calm-row {
  display: flex;
  gap: 12rpx;
}

.emotion-calm-cell {
  flex: 1;
  min-width: 0;
}

.emotion-calm-card {
  min-height: 132rpx;
  padding: 18rpx 12rpx;
}

.emotion-calm-card .card-title {
  font-size: 28rpx;
  line-height: 1.32;
}

.emotion-final-card {
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  background: rgba(255, 253, 248, 0.82);
  color: #5f594f;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.35;
  text-align: center;
  box-sizing: border-box;
}

.care-state-grid {
  gap: 14rpx;
}

.care-state-card {
  min-height: 154rpx;
}

.list-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(103, 87, 64, 0.14);
}

.list-row-meta {
  font-size: 22rpx;
  letter-spacing: 0;
  color: #7a6f5e;
}

.list-row-title {
  font-size: 28rpx;
  line-height: 1.56;
  color: #222722;
}

.list-row-desc {
  font-size: 24rpx;
  line-height: 1.68;
  color: #596058;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  padding: 22rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #f7f1e3, #ede2cf);
  border: 1rpx solid rgba(107, 89, 65, 0.14);
}

.stat-label {
  font-size: 22rpx;
  letter-spacing: 0;
  color: #7a6f5e;
}

.stat-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 650;
  color: #202520;
}

.stats-card-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stats-cell {
  flex: 1;
  min-width: 0;
}

.stats-state-card {
  min-height: 220rpx;
  padding: 20rpx 16rpx;
  gap: 10rpx;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
}

.stats-state-title {
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 650;
  color: #202520;
}

.stats-state-count {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.08);
  color: #4f5d52;
  font-size: 21rpx;
  line-height: 1.3;
}

.stats-detail-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  width: 100%;
}

.stats-detail {
  color: #625f57;
  font-size: 21rpx;
  line-height: 1.42;
}

.nav-rail {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 16rpx;
  background: rgba(99, 84, 62, 0.06);
}

.nav-rail-link {
  min-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 253, 248, 0.84);
  border: 1rpx solid rgba(108, 92, 70, 0.12);
  color: #5e685f;
  font-size: 24rpx;
}

.nav-rail-link--active {
  background: linear-gradient(180deg, #33463a, #233128);
  border-color: rgba(24, 37, 29, 0.24);
  color: #fbf7ef;
}

.axis-page-stack {
  gap: 16rpx;
}

.axis-compact-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  padding: 8rpx 2rpx 2rpx;
}

.axis-compact-title {
  flex: 1;
  min-width: 0;
  color: #202520;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.28;
}

.axis-compact-meta {
  flex-shrink: 0;
  color: #756a58;
  font-size: 23rpx;
  line-height: 1.4;
}

.axis-entry-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.axis-entry-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.88);
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.axis-entry-card--saved {
  min-height: 92rpx;
  justify-content: center;
}

.axis-entry-label {
  color: #746652;
  font-size: 22rpx;
  letter-spacing: 0;
  line-height: 1.3;
}

.axis-entry-input {
  width: 100%;
  height: 66rpx;
  min-height: 66rpx;
  max-height: 66rpx;
  padding: 8rpx 0;
  box-sizing: border-box;
  color: #202520;
  font-size: 27rpx;
  line-height: 32rpx;
  background: transparent;
}

.axis-entry-value {
  color: #202520;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.axis-save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #34473b, #26362d);
  border: 1rpx solid rgba(24, 37, 29, 0.24);
  color: #fbf7ef;
  font-size: 27rpx;
  font-weight: 650;
}

.axis-save-button[disabled] {
  background: linear-gradient(180deg, #eee4d3, #e2d5bf);
  border-color: rgba(102, 82, 58, 0.18);
  color: #6c6254;
}

.empty-state {
  padding: 28rpx;
  border-radius: 18rpx;
  border: 1rpx dashed rgba(111, 94, 70, 0.22);
  background: rgba(245, 239, 228, 0.5);
  font-size: 26rpx;
  line-height: 1.7;
  color: #6f6658;
}

.home-axis-stack {
  gap: 0;
}

.home-hero {
  align-items: center;
  text-align: center;
}

.home-hero .body {
  max-width: 500rpx;
}

.home-slogan {
  color: #6b665c;
  font-size: 26rpx;
  line-height: 1.58;
}

.home-axis-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 26rpx 24rpx 24rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(245, 238, 225, 0.9)),
    linear-gradient(90deg, rgba(92, 108, 89, 0.16), rgba(92, 108, 89, 0.16));
  background-size: auto, 8rpx 100%;
  background-repeat: no-repeat;
  border: 1rpx solid rgba(116, 96, 69, 0.15);
  box-shadow:
    0 10rpx 22rpx rgba(73, 57, 38, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.home-axis-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.home-axis-chip {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(49, 69, 58, 0.08);
  color: #586457;
  font-size: 21rpx;
  line-height: 1.2;
}

.home-axis-input {
  width: 100%;
  height: 92rpx;
  min-height: 92rpx;
  max-height: 92rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(110, 92, 68, 0.14);
  border-radius: 14rpx;
  background: rgba(255, 253, 248, 0.78);
  box-sizing: border-box;
  color: #202520;
  font-size: 28rpx;
  line-height: 32rpx;
  text-align: center;
}

.home-axis-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #34473b, #26362d);
  border: 1rpx solid rgba(24, 37, 29, 0.24);
  color: #fbf7ef;
  font-size: 27rpx;
  font-weight: 650;
  box-shadow:
    0 12rpx 22rpx rgba(34, 45, 37, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.home-axis-submit[disabled] {
  background: linear-gradient(180deg, #eee4d3, #e2d5bf);
  border-color: rgba(102, 82, 58, 0.18);
  color: #6c6254;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.home-axis-task {
  display: block;
  text-align: center;
  color: #202520;
  font-size: 34rpx;
  font-weight: 650;
  line-height: 1.56;
}

.home-axis-footnote {
  display: block;
  text-align: center;
  color: #6b6357;
  font-size: 23rpx;
  line-height: 1.5;
}

.state-grid {
  gap: 16rpx;
}

.state-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.state-cell {
  flex: 1;
  min-width: 0;
}
