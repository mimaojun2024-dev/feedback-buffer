}

.tired-care-reassurance-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(48, 68, 56, 0.18);
  background: linear-gradient(180deg, #f4f1e6, #e4eadc);
  box-shadow:
    0 12rpx 24rpx rgba(58, 70, 59, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

