.month-completed-lock-copy {
  color: #202520;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.month-completed-summary {
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.92), rgba(239, 231, 216, 0.82)),
    linear-gradient(90deg, rgba(92, 108, 89, 0.12), rgba(92, 108, 89, 0));
  background-size: auto, 8rpx 100%;
  background-repeat: no-repeat;
}

.month-completed-history-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.12);
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.78), rgba(242, 235, 221, 0.62)),
    linear-gradient(90deg, rgba(124, 98, 62, 0.08) 1rpx, transparent 1rpx);
  background-size: auto, 30rpx 30rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.76);
}

.month-completed-history-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.month-completed-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.month-completed-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.13);
  background: rgba(255, 253, 248, 0.78);
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.month-completed-date {
  flex-shrink: 0;
  min-width: 72rpx;
  min-height: 36rpx;
