  background: linear-gradient(180deg, #f7f2e7, #e9eddf);
  box-shadow:
    0 14rpx 26rpx rgba(92, 108, 89, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.tired-care-reassurance-card--bright {
  background: linear-gradient(180deg, #fff5df, #e8eddc);
  border-color: rgba(139, 104, 55, 0.18);
  box-shadow:
    0 16rpx 30rpx rgba(139, 104, 55, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.tired-care-reassurance-card--max {
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 223, 148, 0.58), transparent 34%),
    linear-gradient(180deg, #fff7e7, #dfeada);
  border-color: rgba(154, 114, 65, 0.26);
  box-shadow:
    0 20rpx 42rpx rgba(112, 90, 54, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.tired-care-reassurance-main {
  color: #233128;
  font-size: 40rpx;
  font-weight: 750;
  line-height: 1.3;
}

.tired-care-celebration-text {
  color: #536357;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.35;
}

.tired-care-firework {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tired-care-burst {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 120rpx;
  height: 120rpx;
  margin-left: -60rpx;
  margin-top: -60rpx;
  border-radius: 999rpx;
  background: rgba(255, 222, 145, 0.28);
  opacity: 0;
  animation: tired-care-burst 1050ms ease-out both;
}

.tired-care-spark {
  position: absolute;
  color: #9a7241;
  font-size: 26rpx;
  line-height: 1;
  opacity: 0;
  animation: tired-care-spark 1200ms ease-out both;
}

.tired-care-reassurance-card--bright .tired-care-spark {
  color: #8a6f38;
  font-size: 30rpx;
}

.tired-care-reassurance-card--max .tired-care-burst {
  width: 180rpx;
  height: 180rpx;
  margin-left: -90rpx;
  margin-top: -90rpx;
  background: rgba(255, 212, 102, 0.34);
  animation-duration: 1300ms;
}

.tired-care-reassurance-card--max .tired-care-spark {
  color: #8a6536;
  font-size: 36rpx;
  animation-duration: 1400ms;
}

.tired-care-spark--one {
  left: 20%;
  top: 24%;
}

.tired-care-spark--two {
  left: 35%;
  top: 14%;
  animation-delay: 90ms;
}

.tired-care-spark--three {
  right: 34%;
  top: 20%;
  animation-delay: 150ms;
}

.tired-care-spark--four {
  right: 18%;
  top: 34%;
  animation-delay: 220ms;
}

.tired-care-spark--five {
  left: 50%;
  bottom: 18%;
  animation-delay: 280ms;
}

.tired-care-spark--six {
  left: 14%;
  bottom: 28%;
  animation-delay: 330ms;
}

.tired-care-spark--seven {
  right: 13%;
  bottom: 22%;
  animation-delay: 380ms;
}

.tired-care-spark--eight {
  left: 66%;
  top: 12%;
  animation-delay: 430ms;
}

@keyframes tired-care-burst {
  0% {
    opacity: 0;
    transform: scale(0.45);
  }
  42% {
    opacity: 1;
    transform: scale(1);
  }
  100% {
    opacity: 0;
    transform: scale(1.75);
  }
}

@keyframes tired-care-spark {
  0% {
    opacity: 0;
    transform: scale(0.5) translateY(10rpx);
  }
  35% {
    opacity: 1;
    transform: scale(1.22) translateY(-8rpx);
  }
  100% {
    opacity: 0;
    transform: scale(1.7) translateY(-34rpx);
  }
}

