@import "./styles/design-tokens.wxss";

page {
  min-height: 100%;
  background-color: #efe7d8;
  background-image:
    linear-gradient(180deg, rgba(255, 252, 245, 0.68), rgba(235, 224, 206, 0.76)),
    linear-gradient(90deg, rgba(132, 111, 80, 0.05) 1rpx, transparent 1rpx);
  background-size: auto, 36rpx 36rpx;
  color: #24261f;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  padding: 28rpx 22rpx 56rpx;
}

.panel {
  padding: 30rpx 28rpx 32rpx;
  border-radius: 26rpx;
  background-color: rgba(255, 252, 246, 0.96);
  background-image:
    linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(247, 240, 229, 0.26)),
    linear-gradient(90deg, rgba(151, 129, 96, 0.07), rgba(151, 129, 96, 0) 18rpx);
  background-size: auto, 100% 32rpx;
  border: 1rpx solid rgba(112, 94, 68, 0.18);
  box-shadow:
    0 18rpx 46rpx rgba(71, 56, 37, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(134, 113, 83, 0.16);
}

.top-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eyebrow {
  font-size: 22rpx;
  letter-spacing: 0;
  text-transform: uppercase;
  color: #836f55;
}

.kicker {
  font-size: 24rpx;
  color: #736856;
}

.top-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.pill-link,
.nav-rail-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.pill-link {
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: var(--button-secondary-bg);
  border: 1rpx solid var(--button-secondary-border);
  color: #5f4f3c;
  font-size: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.title {
  display: block;
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 700;
  letter-spacing: 0;
  color: #24261f;
}

.title-accent {
  display: block;
  margin-top: 10rpx;
  color: #31453a;
}

.body {
  font-size: 28rpx;
  line-height: 1.66;
  color: #5d5c53;
}

.feedback-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #4d5049;
  font-size: 28rpx;
  line-height: 1.55;
}

.flow-page-stack {
  gap: 18rpx;
}

.flow-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 6rpx 2rpx 4rpx;
}

.flow-hero--center {
  align-items: center;
  text-align: center;
}

.flow-title {
  display: block;
  color: #1f241f;
  font-size: 46rpx;
  font-weight: 720;
  line-height: 1.18;
}

.flow-copy {
  color: #57564f;
  font-size: 25rpx;
  line-height: 1.58;
}

.flow-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.82);
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.flow-card .button-group {
  margin-top: 0;
}

.flow-action-row {
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.flow-action-row .button-primary,
.flow-action-row .button-secondary {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
  text-align: center;
  line-height: 1.35;
}

.flow-timer-card {
  width: 100%;
  min-height: 296rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(46, 61, 50, 0.18);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(235, 226, 209, 0.88));
  box-shadow:
    0 18rpx 36rpx rgba(61, 50, 34, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.timer-encouragement {
  width: 100%;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.12);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.74), rgba(242, 235, 221, 0.56));
  box-sizing: border-box;
  color: #6d665b;
  font-size: 25rpx;
  line-height: 1.5;
  text-align: center;
  letter-spacing: 1rpx;
}

.countdown-task-summary {
  width: 100%;
  min-height: 164rpx;
  justify-content: center;
  padding: 30rpx 28rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(239, 231, 216, 0.88)),
    linear-gradient(90deg, rgba(92, 108, 89, 0.14), rgba(92, 108, 89, 0.14));
  background-size: auto, 9rpx 100%;
  background-repeat: no-repeat;
  box-shadow:
    0 12rpx 26rpx rgba(61, 50, 34, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

.countdown-task-summary .summary-label {
  color: #667061;
  font-size: 25rpx;
  line-height: 1.5;
}

.countdown-task-summary .summary-value {
  font-size: 34rpx;
  line-height: 1.56;
}

.feedback-five-axis-summary {
  gap: 16rpx;
  text-align: left;
}

.feedback-five-axis-summary .summary-label {
  text-align: center;
}

.feedback-five-axis-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feedback-five-axis-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.12);
  background: rgba(255, 253, 248, 0.7);
  box-sizing: border-box;
}

.feedback-five-axis-index {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.1);
  color: #526057;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
}

.feedback-five-axis-task {
  flex: 1;
  min-width: 0;
  color: #202520;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.48;
}

.feedback-five-axis-empty {
  display: block;
  color: #6e675b;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: center;
}

.feedback-five-axis-action {
  align-self: center;
}

.feedback-five-timer-card {
  min-height: 270rpx;
}

.feedback-five-timer-copy {
  color: #6a675d;
  font-size: 24rpx;
  line-height: 1.4;
}

.feedback-five-test-tools {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: -2rpx;
}

.feedback-five-done-actions {
  width: 100%;
  margin-top: 2rpx;
}

.timer--steady {
  font-size: 118rpx;
}

.flow-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.flow-list-item,
.flow-list-button {
  width: 100%;
  min-height: 82rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  background: rgba(255, 253, 248, 0.86);
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.flow-list-mark {
  flex-shrink: 0;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(126, 104, 76, 0.1);
  color: #6a573f;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
}

.flow-list-title {
  flex: 1;
  min-width: 0;
  color: #252b25;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.42;
  text-align: left;
}

.muted {
  color: #827767;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 22rpx 22rpx 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(246, 239, 228, 0.92));
  border: 1rpx solid rgba(116, 96, 69, 0.15);
  box-shadow:
    0 8rpx 18rpx rgba(85, 69, 50, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  overflow: hidden;
}

.card--interactive:active {
  transform: translateY(2rpx);
}

.home-state-card {
  transition: transform 120ms ease, border-color 120ms ease, box-shadow 120ms ease, background 120ms ease;
}

.home-state-card:active,
.home-state-card--pressed {
  transform: translateY(2rpx);
  border-color: var(--action-soft-border);
  background: var(--action-soft-bg);
  box-shadow: var(--action-soft-shadow);
}

.card--selected {
  border-color: rgba(126, 104, 76, 0.26);
  background: linear-gradient(180deg, #fbf5e9, #eee1cc);
  box-shadow:
    0 10rpx 24rpx rgba(85, 69, 50, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.card-title {
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 650;
  color: #24261f;
}

.card-desc {
  font-size: 26rpx;
  line-height: 1.58;
  color: #636057;
}

.card-count {
  display: inline-block;
  margin-top: 4rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(126, 104, 76, 0.08);
  color: #6d604d;
  font-size: 22rpx;
}

.card--grid {
  width: 100%;
  min-height: 184rpx;
  padding: 22rpx 16rpx;
  gap: 10rpx;
  box-sizing: border-box;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.card--grid .card-title {
  font-size: 30rpx;
  line-height: 1.34;
}

.card--grid .card-desc {
  max-width: 220rpx;
  font-size: 22rpx;
  line-height: 1.58;
  color: #625f57;
}

.state-card-head,
.stats-state-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.state-card-emoji {
  display: block;
  font-size: 34rpx;
  line-height: 1;
}

.state-card-name {
  color: #24261f;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.3;
  text-align: center;
}

.summary {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(245, 240, 229, 0.98), rgba(237, 231, 218, 0.92));
  border: 1rpx solid rgba(106, 90, 67, 0.14);
  box-shadow: inset 8rpx 0 0 rgba(50, 70, 58, 0.12);
}

.summary-label {
  font-size: 22rpx;
  letter-spacing: 0;
  text-transform: uppercase;
  color: #776a58;
}

.summary-value {
  font-size: 31rpx;
  line-height: 1.62;
  font-weight: 600;
  color: #202520;
}

.choice-summary {
  align-items: center;
  text-align: center;
}

.summary--quiet {
  box-shadow: inset 6rpx 0 0 rgba(50, 70, 58, 0.1);
}

.start-task-summary {
  position: relative;
  padding: 24rpx 24rpx 64rpx;
}

.action-summary {
  position: relative;
  padding-bottom: 70rpx;
}

.action-summary-button {
  position: absolute;
  right: 18rpx;
  bottom: 16rpx;
}

.start-action-group {
  margin-top: -4rpx;
}

.start-countdown-button {
  min-height: 86rpx;
  border-radius: 18rpx;
}

.button-ghost.start-task-edit {
  position: absolute;
  right: 18rpx;
  bottom: 16rpx;
  border: 1rpx solid rgba(102, 82, 58, 0.14);
  color: #6e665b;
}

.start-history-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 4rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.12);
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.8), rgba(242, 235, 221, 0.62)),
    linear-gradient(90deg, rgba(124, 98, 62, 0.08) 1rpx, transparent 1rpx);
  background-size: auto, 30rpx 30rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.76);
}

.start-history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.start-history-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.start-history-empty,
.start-history-time {
  color: #7a6f5e;
  font-size: 22rpx;
  line-height: 1.45;
}

.start-history-label {
  color: #5c655a;
}

.start-history-empty {
  display: block;
  padding: 12rpx 2rpx 2rpx;
  white-space: nowrap;
}

.button-ghost.start-history-manage {
  flex-shrink: 0;
  margin-left: auto;
}

.start-history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.start-history-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.13);
  background: rgba(255, 253, 248, 0.78);
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.start-history-item-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.start-history-task {
  color: #252b25;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.45;
}

.button-ghost.start-history-delete {
  flex-shrink: 0;
}

.feedback-axis-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(89, 74, 53, 0.16);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(239, 231, 216, 0.9));
  box-shadow: inset 8rpx 0 0 rgba(50, 70, 58, 0.12);
}

.feedback-axis-panel--month {
  background: linear-gradient(180deg, rgba(250, 246, 236, 0.94), rgba(235, 226, 210, 0.88));
  box-shadow: inset 8rpx 0 0 rgba(122, 96, 58, 0.1);
}

.feedback-axis-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feedback-axis-link {
  flex-shrink: 0;
  color: #715f47;
  font-size: 23rpx;
  font-weight: 650;
}

.feedback-axis-main {
  color: #202520;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.5;
}

.feedback-axis-empty {
  color: #766c5c;
  font-size: 25rpx;
  line-height: 1.55;
}

.feedback-month-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.feedback-month-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.feedback-month-index {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.1);
  color: #3d4e42;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
}

.feedback-month-task {
  flex: 1;
  min-width: 0;
  color: #343932;
  font-size: 25rpx;
  line-height: 1.45;
}

.input-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  letter-spacing: 0;
  color: #625947;
}

.textarea {
  width: 100%;
  height: 104rpx;
  min-height: 104rpx;
  max-height: 104rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(108, 92, 70, 0.2);
  background: rgba(255, 253, 249, 0.96);
  box-sizing: border-box;
  box-shadow: inset 0 2rpx 10rpx rgba(120, 104, 82, 0.05);
  font-size: 28rpx;
  line-height: 34rpx;
  color: #1f241f;
}

.textarea--compact {
  height: 96rpx;
  min-height: 96rpx;
  max-height: 96rpx;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 28rpx;
}

.button-group.flow-action-row {
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.button-group--split {
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;
  gap: 14rpx;
}

.button-primary,
.button-secondary,
.button-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 650;
}

.button-primary {
  background: var(--action-soft-bg);
  border: 1rpx solid var(--action-soft-border);
  color: var(--action-soft-ink);
  box-shadow: var(--action-soft-shadow);
}

.button-primary[disabled] {
  background: var(--button-disabled-bg);
  border-color: var(--button-disabled-border);
  color: var(--button-disabled-ink);
  box-shadow: none;
}

.button-secondary {
  background: var(--button-quiet-bg);
  border: 1rpx solid var(--button-quiet-border);
  color: var(--button-quiet-ink);
  box-shadow: var(--button-quiet-shadow);
}

.button-secondary--panel {
  width: calc(50% - 7rpx);
  min-height: 114rpx;
  align-items: flex-start;
  justify-content: center;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 18rpx 16rpx;
}

.button-ghost {
  min-height: 68rpx;
  justify-content: flex-start;
  padding: 0;
  border-radius: 0;
  color: #6f604c;
  font-size: 25rpx;
  font-weight: 500;
  background: transparent;
}

.button-ghost.micro-action-button,
.micro-action-button {
  width: auto;
  min-width: 76rpx;
  min-height: 42rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(116, 95, 69, 0.14);
  background: rgba(255, 253, 248, 0.66);
  color: #715f47;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  box-sizing: border-box;
}

.button-ghost.micro-action-button--danger,
.micro-action-button--danger {
  border-color: rgba(128, 74, 54, 0.12);
  background: rgba(128, 74, 54, 0.08);
  color: #8a523d;
}

.test-tools {
  display: flex;
  justify-content: center;
  margin-top: -4rpx;
}

.test-reset-button {
  min-height: 54rpx;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx dashed rgba(116, 95, 69, 0.26);
  background: rgba(255, 253, 248, 0.58);
  color: #7a6f5e;
  font-size: 23rpx;
}

.courage-action-group {
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: space-between;
  gap: 14rpx;
}

.courage-flow-card {
  gap: 14rpx;
  padding: 18rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.9), rgba(242, 235, 221, 0.72));
}

.courage-input {
  height: 100rpx;
  min-height: 100rpx;
  max-height: 100rpx;
}

.courage-action-button {
  flex: 1;
  min-width: 0;
  min-height: 108rpx;
  padding: 0 18rpx;
  text-align: center;
  line-height: 1.35;
}

.courage-action-group--retry {
  margin-top: -4rpx;
}

.courage-encouragement-card {
  margin-top: -2rpx;
}

.courage-done-actions {
  flex-direction: row;
  flex-wrap: nowrap;
}

.drag-done-actions {
  flex-direction: row;
  flex-wrap: nowrap;
}

.button-panel-title {
  font-size: 30rpx;
  font-weight: 650;
  color: #2f2921;
}

.button-panel-meta {
  font-size: 22rpx;
  color: #716654;
}

.micro-copy {
  margin-top: 18rpx;
  font-size: 24rpx;
