  flex: 1;
  min-width: 0;
  align-items: flex-start;
}

.stats-state-count {
  flex-shrink: 0;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(126, 104, 76, 0.08);
  color: #6d604d;
  font-size: 21rpx;
  line-height: 1.25;
}

.stats-detail-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 100%;
}

.stats-detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-height: 44rpx;
  padding: 8rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(255, 253, 248, 0.72);
  border: 1rpx solid rgba(103, 87, 64, 0.08);
  box-sizing: border-box;
}

.stats-detail-label {
  flex-shrink: 0;
  color: #7a6f5e;
  font-size: 20rpx;
  line-height: 1.35;
}

.stats-detail-value {
  flex: 1;
  min-width: 0;
  color: #333932;
  font-size: 21rpx;
  font-weight: 620;
  line-height: 1.38;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-rail {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 16rpx;
  background: rgba(99, 84, 62, 0.06);
}

.nav-rail-link {
  min-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 253, 248, 0.84);
  border: 1rpx solid rgba(108, 92, 70, 0.12);
  color: #665d4e;
  font-size: 24rpx;
}

.nav-rail-link--active {
  background: var(--action-soft-bg);
  border-color: var(--action-soft-border);
  color: var(--action-soft-ink);
  box-shadow: var(--action-soft-shadow);
}

.axis-page-stack {
  gap: 16rpx;
}

.axis-compact-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  padding: 8rpx 2rpx 2rpx;
}

.axis-head-action {
  flex-shrink: 0;
  margin-left: auto;
}

.axis-compact-title {
  flex: 1;
  min-width: 0;
  color: #202520;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.28;
}

.axis-compact-meta {
  flex-shrink: 0;
  color: #756a58;
  font-size: 23rpx;
  line-height: 1.4;
}

.axis-entry-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.axis-entry-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.88);
  border: 1rpx solid rgba(103, 87, 64, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.axis-entry-card--saved {
  min-height: 92rpx;
  justify-content: center;
}

.axis-entry-label {
  color: #746652;
  font-size: 22rpx;
  letter-spacing: 0;
  line-height: 1.3;
}

