  width: 100%;
  height: 66rpx;
  min-height: 66rpx;
  max-height: 66rpx;
  padding: 8rpx 0;
  box-sizing: border-box;
  color: #202520;
  font-size: 27rpx;
  line-height: 32rpx;
  background: transparent;
}

.axis-entry-value {
  color: #202520;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.axis-save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 14rpx;
  background: var(--action-soft-bg);
  border: 1rpx solid var(--action-soft-border);
  color: var(--action-soft-ink);
  font-size: 27rpx;
  font-weight: 650;
  box-shadow: var(--action-soft-shadow);
}

.axis-save-button[disabled] {
  background: var(--button-disabled-bg);
  border-color: var(--button-disabled-border);
  color: var(--button-disabled-ink);
  box-shadow: none;
}

.empty-state {
  padding: 28rpx;
  border-radius: 18rpx;
  border: 1rpx dashed rgba(111, 94, 70, 0.22);
  background: rgba(245, 239, 228, 0.5);
  font-size: 26rpx;
  line-height: 1.7;
  color: #6f6658;
}

.home-axis-stack {
  gap: 14rpx;
  padding: 22rpx 18rpx 18rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.82), rgba(242, 234, 219, 0.62)),
    linear-gradient(90deg, rgba(126, 104, 76, 0.06) 1rpx, transparent 1rpx);
  background-size: auto, 30rpx 30rpx;
  border: 1rpx solid rgba(116, 96, 69, 0.14);
  box-shadow:
    0 10rpx 24rpx rgba(71, 56, 37, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
}

.home-page-shell {
  padding-top: 44rpx;
}

@media (max-height: 700px) {
  .home-page-shell {
    padding-top: 34rpx;
  }
}

@media (min-height: 820px) {
  .home-page-shell {
    padding-top: 56rpx;
  }
}

.home-stack {
  min-height: calc(100vh - 190rpx);
}

.home-hero {
  align-items: center;
  text-align: center;
}

.home-hero .body {
  max-width: 500rpx;
}

.home-slogan {
  color: #6b665c;
  font-size: 26rpx;
  line-height: 1.58;
}

.home-checkin-actions {
  margin-top: 0;
}

.home-checkin-actions .button-secondary--panel {
  align-items: center;
  text-align: center;
}

.home-checkin-button {
  min-height: 94rpx;
  padding: 16rpx 14rpx 14rpx;
  border-radius: 14rpx;
  background: var(--button-quiet-bg);
  border-color: var(--button-quiet-border);
  color: var(--button-quiet-ink);
  box-shadow: var(--button-quiet-shadow);
}

.home-checkin-button[disabled] {
  background: rgba(238, 232, 220, 0.48);
  border-color: rgba(116, 95, 69, 0.1);
  color: rgba(83, 78, 69, 0.5);
  box-shadow: none;
}

.home-checkin-button[disabled] .button-panel-title {
  color: rgba(55, 51, 43, 0.52);
}

.home-checkin-button--end.home-checkin-button--disabled {
  background: rgba(238, 232, 220, 0.48);
  border-color: rgba(116, 95, 69, 0.1);
  color: rgba(83, 78, 69, 0.5);
  box-shadow: none;
}

.home-checkin-button--disabled .button-panel-meta {
  color: rgba(100, 91, 76, 0.56);
}

.home-checkin-actions .button-panel-title,
.home-checkin-actions .button-panel-meta {
  width: 100%;
  text-align: center;
}

.home-checkin-actions .button-panel-title {
  color: var(--button-quiet-ink);
}

.home-checkin-actions .button-panel-meta {
  color: var(--button-quiet-ink);
}

.home-checkin-actions .home-checkin-button[disabled] .button-panel-title {
  color: rgba(55, 51, 43, 0.52);
}

.home-checkin-actions .home-checkin-button[disabled] .button-panel-meta,
.home-checkin-actions .home-checkin-button--disabled .button-panel-meta {
  color: rgba(100, 91, 76, 0.56);
}

.closing-line {
  display: flex;
  justify-content: center;
  padding: 4rpx 0 0;
  color: #7a705f;
  font-size: 22rpx;
  line-height: 1.6;
  letter-spacing: 1rpx;
  text-align: center;
}

.home-closing-line {
  margin-top: 30rpx;
  padding-bottom: 10rpx;
}

.stats-closing-line {
  margin-top: 12rpx;
}

.home-axis-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 2rpx 6rpx 4rpx;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
  box-sizing: border-box;
}

.home-axis-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.home-axis-pin {
  font-size: 24rpx;
  line-height: 1;
  transform: rotate(-10deg);
}

.home-axis-input {
  width: 100%;
  height: 92rpx;
  min-height: 92rpx;
  max-height: 92rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(110, 92, 68, 0.14);
  border-radius: 14rpx;
  background: rgba(255, 253, 248, 0.78);
  box-sizing: border-box;
  color: #202520;
  font-size: 28rpx;
  line-height: 32rpx;
  text-align: center;
}

.home-axis-task {
  display: block;
  text-align: center;
  color: #202520;
  font-size: 34rpx;
  font-weight: 650;
  line-height: 1.56;
}

.home-axis-footnote {
  display: block;
  text-align: center;
  color: #6b6357;
  font-size: 23rpx;
  line-height: 1.5;
}

.state-grid {
  gap: 16rpx;
}

.state-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.state-cell {
  flex: 1;
  min-width: 0;
}

.button-preferred {
  background: var(--action-soft-bg);
  border-color: var(--action-soft-border);
  color: var(--action-soft-ink);
  box-shadow: var(--action-soft-shadow);
}

.button-preferred .button-panel-title,
.button-preferred .button-panel-meta {
  color: var(--action-soft-ink);
}

.button-preferred[disabled] {
  background: var(--button-disabled-bg);
  border-color: var(--button-disabled-border);
  color: var(--button-disabled-ink);
  box-shadow: none;
}

.button-preferred[disabled] .button-panel-title,
.button-preferred[disabled] .button-panel-meta {
  color: var(--button-disabled-ink);
}

.drag-choice-card--preferred {
  border-color: var(--action-soft-border);
  background: var(--action-soft-bg);
  box-shadow: var(--action-soft-shadow);
}

.drag-choice-card--preferred .drag-choice-title {
  color: var(--action-soft-ink);
}
