  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(50, 70, 58, 0.1);
  color: #526057;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
  box-sizing: border-box;
}

.month-completed-item-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #252b25;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.45;
}

.month-completed-empty {
  padding: 18rpx 2rpx 4rpx;
}

.stats-panel {
  background-image:
    linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(247, 240, 229, 0.22)),
    linear-gradient(90deg, rgba(151, 129, 96, 0.06), rgba(151, 129, 96, 0) 18rpx),
    radial-gradient(circle at 8% 4%, rgba(92, 108, 89, 0.09), transparent 34%);
}

.stats-stack {
  gap: 18rpx;
}

.stats-hero-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(56, 76, 62, 0.16);
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(235, 226, 209, 0.86)),
    linear-gradient(90deg, rgba(49, 69, 58, 0.14), rgba(49, 69, 58, 0.14));
  background-size: auto, 8rpx 100%;
  background-repeat: no-repeat;
  box-shadow:
    0 14rpx 30rpx rgba(61, 50, 34, 0.09),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
  text-align: center;
}

.stats-hero-label {
  color: #667061;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.3;
}

.stats-hero-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
}

.stats-hero-number {
  color: #1f241f;
  font-size: 66rpx;
  font-weight: 780;
  line-height: 1;
}

.stats-hero-unit {
  color: #4f5d52;
  font-size: 25rpx;
  font-weight: 650;
}

.stats-insight-row {
  display: flex;
  gap: 14rpx;
}

.stats-insight-card {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-height: 104rpx;
  padding: 18rpx 16rpx;
  border-radius: 17rpx;
  border: 1rpx solid rgba(103, 87, 64, 0.12);
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.82), rgba(243, 236, 222, 0.66));
  box-sizing: border-box;
  text-align: center;
}

.stats-insight-label {
  color: #7a6f5e;
  font-size: 21rpx;
  line-height: 1.3;
}

.stats-insight-value {
  color: #242a24;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.38;
}

.stats-section-head {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 2rpx 0;
}

.stats-section-title {
  color: #1f241f;
  font-size: 31rpx;
  font-weight: 720;
  line-height: 1.35;
}

.stats-card-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stats-cell {
  flex: 1;
  min-width: 0;
}

.stats-state-card {
  min-height: 218rpx;
  padding: 18rpx 16rpx;
  gap: 14rpx;
  box-sizing: border-box;
}

.stats-state-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  width: 100%;
}

