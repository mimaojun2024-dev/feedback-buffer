page {
  --paper-white: #fffdf8;
  --paper-warm: #f6efe2;
  --paper-warm-deep: #eadfcb;
  --ink-main: #24261f;
  --ink-soft: #6b6357;
  --line-warm: rgba(116, 95, 69, 0.16);

  --action-soft-bg: linear-gradient(180deg, #fbf8ef, #eef1e5);
  --action-soft-bg-pressed: linear-gradient(180deg, #f8f8ed, #e5eddd);
  --action-soft-border: rgba(92, 108, 89, 0.24);
  --action-soft-ink: #344238;
  --action-soft-shadow: 0 12rpx 24rpx rgba(92, 108, 89, 0.1), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);

  --button-secondary-bg: linear-gradient(180deg, #f6efe2, #eadfcb);
  --button-secondary-border: rgba(116, 95, 69, 0.18);
  --button-secondary-ink: #3a2f24;
  --button-secondary-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);

  --button-quiet-bg: linear-gradient(180deg, rgba(255, 253, 248, 0.78), rgba(238, 232, 220, 0.56));
  --button-quiet-border: rgba(116, 95, 69, 0.1);
  --button-quiet-ink: #766b59;
  --button-quiet-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);

  --button-disabled-bg: rgba(239, 232, 219, 0.54);
  --button-disabled-border: rgba(116, 95, 69, 0.12);
  --button-disabled-ink: rgba(100, 91, 76, 0.56);
}
