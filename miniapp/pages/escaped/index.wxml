<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack flow-page-stack escaped-page-stack">
      <view class="flow-hero flow-hero--center escaped-home-hero">
        <text class="flow-title">先把自己拉回来</text>
        <text class="flow-copy">不用解释为什么逃开，先选一个动作重新接管。</text>
      </view>

      <view class="card-list state-grid escaped-state-grid">
        <view wx:for="{{actionRows}}" wx:for-item="row" wx:key="index" class="state-row">
          <view wx:for="{{row}}" wx:for-item="action" wx:key="id" class="state-cell">
            <view
              class="card card--interactive card--grid escaped-state-card {{selectedActionId === action.id ? 'card--selected' : ''}}"
              bindtap="handleSelect"
              data-id="{{action.id}}"
            >
              <view class="state-card-head">
                <text class="state-card-emoji">{{action.emoji}}</text>
                <text class="state-card-name">{{action.label}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <block wx:if="{{selectedActionPrompt}}">
        <view class="escaped-return-panel">
          <text class="escaped-return-title">{{selectedActionPrompt}}</text>
          <text class="escaped-return-copy">先做这一件，其他都晚点再说。</text>
        </view>

        <view class="button-group flow-action-row escaped-return-actions">
          <navigator url="/pages/axis-today/index" class="button-primary">回到今日主轴</navigator>
          <navigator url="/pages/home/index" class="button-secondary">回到主页</navigator>
        </view>
      </block>
    </view>
  </view>
</view>
