<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">状态入口</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
        <text class="badge">重新接管</text>
      </view>
    </view>

    <view class="stack escaped-page-stack">
      <view class="stack home-hero escaped-home-hero">
        <text class="title">我逃开了</text>
        <text class="body">先选一个动作。</text>
      </view>

      <view class="card-list state-grid escaped-state-grid">
        <view wx:for="{{actionRows}}" wx:for-item="row" wx:key="index" class="state-row">
          <view wx:for="{{row}}" wx:for-item="action" wx:key="id" class="state-cell">
            <view
              class="card card--interactive card--grid escaped-state-card {{selectedActionId === action.id ? 'card--selected' : ''}}"
              bindtap="handleSelect"
              data-id="{{action.id}}"
            >
              <text class="card-title">{{action.label}}</text>
              <text class="card-desc">{{action.hint}}</text>
            </view>
          </view>
        </view>
      </view>

      <block wx:if="{{selectedActionId}}">
        <view class="escaped-return-panel">
          <view class="escaped-return-texts">
            <text class="escaped-return-copy">做完这一件，再回主页。</text>
          </view>
          <navigator url="/pages/home/index" class="escaped-return-button">回到主页</navigator>
        </view>
      </block>
    </view>
  </view>
</view>
