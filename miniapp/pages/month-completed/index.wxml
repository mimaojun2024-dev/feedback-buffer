<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">我的轴线</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" open-type="reLaunch" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack month-completed-stack">
        <view class="nav-rail month-axis-nav">
          <navigator url="/pages/axis-year/index" class="nav-rail-link">年度</navigator>
          <navigator url="/pages/axis-month/index" class="nav-rail-link">月度</navigator>
          <navigator url="/pages/axis-today/index" class="nav-rail-link">今天</navigator>
          <navigator url="/pages/month-completed/index" class="nav-rail-link nav-rail-link--active month-completed-nav-link">本月完成</navigator>
        </view>

        <view class="flow-hero month-completed-hero">
          <text class="flow-title">本月完成</text>
        </view>

        <view class="month-completed-history-panel">
          <view class="month-completed-history-head">
            <text class="summary-label">{{monthLabel}}</text>
          </view>

          <block wx:if="{{monthEntries.length}}">
            <view class="month-completed-list">
              <view wx:for="{{monthEntries}}" wx:key="dateKey" class="month-completed-item">
                <text class="month-completed-date">{{item.dateLabel}}</text>
                <text class="month-completed-item-title">{{item.completedThing || '还没写完成事项'}}</text>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="empty-state month-completed-empty">这个月还没有记录</view>
          </block>
        </view>
    </view>
  </view>
</view>
