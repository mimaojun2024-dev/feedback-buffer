<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack drag-check-stack">
      <view class="drag-check-hero">
        <view class="drag-check-title">
          <text>只做两分钟</text>
          <text class="drag-check-title-accent">可以吗</text>
        </view>
        <view class="drag-check-copy">
          <text>先不谈宏大目标。</text>
          <text>只问这两分钟，能不能借给第一步。</text>
        </view>
      </view>

      <view class="drag-choice-row">
        <button class="drag-choice-card {{selectedAnswer === 'yes' ? 'drag-choice-card--selected' : ''}}" bindtap="handleSelect" data-answer="yes">
          <text class="drag-choice-title">可以</text>
          <text class="drag-choice-desc">先碰第一步</text>
        </button>
        <button class="drag-choice-card {{selectedAnswer === 'no' ? 'drag-choice-card--selected' : ''}}" bindtap="handleSelect" data-answer="no">
          <text class="drag-choice-title">不可以</text>
          <text class="drag-choice-desc">先退半步</text>
        </button>
      </view>

      <block wx:if="{{selectedAnswer === 'no'}}">
        <view class="drag-encouragement-card" bindtap="handleOpenEncouragement">
          <text class="drag-encouragement-title">再想想呢？</text>
          <text class="drag-encouragement-copy">不用启动整个世界</text>
          <text class="drag-encouragement-hint">只把门缝推开一点，也算开始</text>
        </view>

        <block wx:if="{{encouragementOpened}}">
          <view class="drag-choice-row drag-choice-row--retry">
            <button class="drag-choice-card {{retryAnswer === 'yes' ? 'drag-choice-card--selected' : ''}}" bindtap="handleRetrySelect" data-answer="yes">
              <text class="drag-choice-title">可以</text>
              <text class="drag-choice-desc">只推开一点</text>
            </button>
            <button class="drag-choice-card {{retryAnswer === 'no' ? 'drag-choice-card--selected' : ''}}" bindtap="handleRetrySelect" data-answer="no">
              <text class="drag-choice-title">不可以</text>
              <text class="drag-choice-desc">先保住自己</text>
            </button>
          </view>
        </block>
      </block>

      <block wx:if="{{retryAnswer === 'no'}}">
        <navigator url="/pages/home/index" class="button-secondary">休息一下</navigator>
      </block>
    </view>
  </view>
</view>
