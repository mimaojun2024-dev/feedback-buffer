<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">主轴</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
        <text class="badge">今天</text>
      </view>
    </view>

    <view class="stack">
      <view class="nav-rail">
        <navigator url="/pages/axis-year/index" class="nav-rail-link">年度</navigator>
        <navigator url="/pages/axis-month/index" class="nav-rail-link">月度</navigator>
        <text class="nav-rail-link nav-rail-link--active">今天</text>
      </view>

      <view class="stack">
        <text class="title">今天最重要的事</text>
        <text class="body">只保留一件最主要的事。今天先把现实动作钉住。</text>
      </view>

      <block wx:if="{{isEditing}}">
        <view class="stack">
          <text class="input-label">最主要的任务</text>
          <textarea class="textarea textarea--compact" value="{{task}}" placeholder="写下今天最重要的那件事" bindinput="handleTaskInput" />
          <button class="button-primary" bindtap="handleSave" disabled="{{!canSave}}">保存今天这件事</button>
        </view>
      </block>

      <block wx:else>
        <view class="summary">
          <text class="summary-label">今天最重要的事</text>
          <text class="summary-value">{{task}}</text>
        </view>
      </block>

      <view class="stack">
        <text class="input-label">提交的每天完成</text>
        <block wx:if="{{recentCompletions.length}}">
          <view class="list-rows">
            <view wx:for="{{recentCompletions}}" wx:key="dateKey" class="list-row">
              <text class="list-row-meta">{{item.dateLabel}} · 开始 {{item.startLabel}} / 收束 {{item.endLabel}}</text>
              <text class="list-row-title">{{item.completedThing}}</text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="empty-state">还没有提交过每天完成。</view>
        </block>
      </view>

      <block wx:if="{{!isEditing}}">
        <button class="button-ghost" bindtap="handleEdit">修改今天这件事</button>
      </block>
    </view>
  </view>
</view>
