<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">反馈缓冲</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
        <text class="badge">今天已缓冲 {{dailyCount}} 次</text>
      </view>
    </view>

    <view class="stack timer-wrap">
      <view class="feedback-timer-card">
        <view class="feedback-timer-line">
          <text class="timer">{{remainingSeconds}}</text>
          <text class="feedback-timer-unit">秒</text>
        </view>
      </view>
      <view class="progress-track">
        <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
      </view>
    </view>
  </view>
</view>
