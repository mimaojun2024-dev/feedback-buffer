<view class="page-shell home-page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/month-completed/index" class="pill-link">我的轴线</navigator>
        <navigator url="/pages/stats/index" class="pill-link">跨过阻碍</navigator>
      </view>
    </view>

    <view class="stack home-stack">
      <view class="stack home-hero">
        <text class="title">稳稳接住自己</text>
        <text class="body home-slogan">慢半拍，就是自由开始出现的地方✨</text>
      </view>

      <view class="stack home-axis-stack">
        <block wx:if="{{hasTodayAxisTask}}">
          <navigator url="/pages/axis-today/index" class="home-axis-card home-axis-card--saved">
            <view class="home-axis-head">
              <text class="home-axis-pin">📌</text>
              <text class="summary-label">今日主轴</text>
            </view>
            <text class="home-axis-task">{{todayAxisTask}}</text>
          </navigator>
        </block>

        <block wx:else>
          <view class="home-axis-card home-axis-card--draft">
            <view class="home-axis-head">
              <text class="summary-label">今日主轴</text>
            </view>
            <textarea
              class="home-axis-input"
              value="{{todayAxisDraft}}"
              placeholder="{{inputPlaceholders.todayAxis}}"
              data-placeholder-key="todayAxis"
              data-placeholder-text="写下今天最重要的一件事"
              bindinput="handleTodayAxisInput"
              bindfocus="handleInputFocus"
              bindblur="handleInputBlur"
            />
          </view>
        </block>

        <view class="button-group button-group--split home-checkin-actions">
          <button
            class="button-secondary button-secondary--panel home-checkin-button home-checkin-button--start {{canStartToday && !hasStartedToday && !canEndToday ? 'button-preferred' : ''}}"
            bindtap="handleStartToday"
            disabled="{{!canStartToday || hasStartedToday}}"
          >
            <text class="button-panel-title">启动今天</text>
            <text class="button-panel-meta">{{startMeta}}</text>
          </button>
          <button
            class="button-secondary button-secondary--panel home-checkin-button home-checkin-button--end {{!canEndToday ? 'home-checkin-button--disabled' : ''}} {{canEndToday && !hasEndedToday ? 'button-preferred' : ''}}"
            bindtap="handleEndToday"
            disabled="{{!canEndToday}}"
          >
            <text class="button-panel-title">收束今天</text>
            <text class="button-panel-meta">{{endMeta}}</text>
          </button>
        </view>
      </view>

      <view class="card-list state-grid">
        <view wx:for="{{stateRows}}" wx:for-item="row" wx:key="index" class="state-row">
          <view
            wx:for="{{row}}"
            wx:for-item="state"
            wx:key="id"
            class="state-cell"
          >
            <view
              class="card card--interactive card--grid home-state-card {{state.id === 'stimulation' ? 'home-state-card--locked' : ''}} {{pressedStateId === state.id && state.id !== 'stimulation' ? 'home-state-card--pressed' : ''}} {{pressedStateId === state.id && state.id === 'stimulation' ? 'home-state-card--locked-pressed' : ''}} {{state.id === 'stimulation' && lockedStateTapCount >= 10 ? 'home-state-card--locked-max' : ''}}"
              bindtap="handleStateTap"
              data-id="{{state.id}}"
              data-route="{{state.route}}"
            >
              <view class="state-card-head">
                <text class="state-card-emoji">{{state.emoji}}</text>
                <text class="state-card-name">{{state.name}}</text>
              </view>
              <text class="card-desc">{{state.id === 'stimulation' ? lockedStateDescription : state.description}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{canResetTodayForTest}}" class="test-tools">
        <button class="button-ghost test-reset-button" bindtap="handleResetTodayForTest">
          重置今日测试
        </button>
      </view>

      <view class="closing-line home-closing-line">
        <text>天之历数在尔躬，允执其中。</text>
      </view>
    </view>
  </view>
</view>
