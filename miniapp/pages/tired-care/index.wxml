<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack flow-page-stack tired-care-stack">
      <view class="flow-hero flow-hero--center tired-care-hero">
        <text class="flow-title">累了，就先照顾自己</text>
        <text class="flow-copy">先选一个恢复动作，不急着证明自己还能撑。</text>
      </view>

      <view class="card-list state-grid care-state-grid">
        <view wx:for="{{optionRows}}" wx:for-item="row" wx:key="index" class="state-row">
          <view wx:for="{{row}}" wx:for-item="option" wx:key="id" class="state-cell">
            <view
              class="card card--interactive card--grid care-state-card {{selectedOptionId === option.id ? 'card--selected' : ''}}"
              bindtap="handleSelect"
              data-id="{{option.id}}"
            >
              <view class="state-card-head">
                <text class="state-card-emoji">{{option.emoji}}</text>
                <text class="state-card-name">{{option.label}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{selectedPrompt}}" class="tired-care-prompt-card" bindtap="handleOpenReassurance">
        <text class="tired-care-prompt-main">{{selectedPrompt}}</text>
        <text class="tired-care-prompt-hint">点一下，接住自己</text>
      </view>

      <view wx:if="{{showReassurance}}" class="tired-care-reassurance-card {{reassuranceCelebrationClass}}" bindtap="handleReassure">
        <view wx:if="{{showReassuranceFirework}}" class="tired-care-firework" aria-hidden="true">
          <view class="tired-care-burst"></view>
          <text class="tired-care-spark tired-care-spark--one">✦</text>
          <text class="tired-care-spark tired-care-spark--two">✧</text>
          <text class="tired-care-spark tired-care-spark--three">✦</text>
          <text class="tired-care-spark tired-care-spark--four">✧</text>
          <text class="tired-care-spark tired-care-spark--five">✦</text>
          <text class="tired-care-spark tired-care-spark--six">✧</text>
          <text class="tired-care-spark tired-care-spark--seven">✦</text>
          <text class="tired-care-spark tired-care-spark--eight">✧</text>
        </view>
        <text class="tired-care-reassurance-main">会好起来的</text>
        <text wx:if="{{reassuranceCelebrationText}}" class="tired-care-celebration-text">{{reassuranceCelebrationText}}</text>
        <text class="tired-care-reassurance-count">{{reassuranceCountText}}</text>
      </view>
    </view>
  </view>
</view>
