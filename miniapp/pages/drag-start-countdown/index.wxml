<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack timer-wrap flow-page-stack">
      <view class="summary countdown-task-summary">
        <text class="summary-label">我现在要做的是</text>
        <text class="summary-value">{{startTask}}</text>
      </view>
      <view class="flow-timer-card">
        <text class="timer timer--steady">{{timeLabel}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
      </view>

      <view class="timer-encouragement">
        <text>不积跬步，无以至千里</text>
      </view>

      <view wx:if="{{canSkipCountdownForTest}}" class="test-tools">
        <button class="button-ghost test-reset-button" bindtap="handleSkipCountdownForTest">
          跳过倒计时
        </button>
      </view>
    </view>
  </view>
</view>
