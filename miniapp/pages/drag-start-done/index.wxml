<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">状态入口</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
        <text class="badge">两分钟到了</text>
      </view>
    </view>

    <view class="stack flow-page-stack">
      <view class="flow-hero flow-hero--center">
        <text class="flow-title">这两分钟已经算数</text>
        <text class="flow-copy">你已经碰到事情本身了。</text>
      </view>

      <block wx:if="{{initialTask}}">
        <view class="summary">
          <text class="summary-label">你刚才碰的是</text>
          <text class="summary-value">{{initialTask}}</text>
        </view>
      </block>

      <view class="button-group flow-action-row">
        <button class="button-primary" bindtap="handleRestart">再做两分钟</button>
        <navigator url="/pages/home/index" class="button-secondary">回到主页</navigator>
      </view>
    </view>
  </view>
</view>
