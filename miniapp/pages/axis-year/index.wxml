<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">主轴</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" open-type="reLaunch" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack axis-page-stack">
      <view class="nav-rail">
        <navigator url="/pages/axis-year/index" class="nav-rail-link nav-rail-link--active">年度</navigator>
        <navigator url="/pages/axis-month/index" class="nav-rail-link">月度</navigator>
        <navigator url="/pages/axis-today/index" class="nav-rail-link">今天</navigator>
      </view>

      <view class="axis-compact-head">
        <text class="axis-compact-title">今年最重要的事</text>
        <text class="axis-compact-meta">先立方向</text>
        <button wx:if="{{!isEditing}}" class="button-ghost micro-action-button axis-head-action" bindtap="handleEdit">修改</button>
      </view>

      <block wx:if="{{isEditing}}">
        <view class="axis-entry-list">
          <view wx:for="{{entries}}" wx:key="index" class="axis-entry-card">
            <text class="axis-entry-label">方向 {{index + 1}}</text>
            <textarea
              class="axis-entry-input"
              value="{{item.task}}"
              placeholder="{{inputPlaceholders.axisEntry}}"
              data-index="{{index}}"
              data-placeholder-key="axisEntry"
              data-placeholder-text="写下这一条方向"
              bindinput="handleInput"
              bindfocus="handleInputFocus"
              bindblur="handleInputBlur"
            />
          </view>
          <button class="axis-save-button" bindtap="handleSave" disabled="{{!canSave}}">保存这几条</button>
        </view>
      </block>

      <block wx:else>
        <view class="axis-entry-list">
          <view wx:for="{{entries}}" wx:key="index" wx:if="{{item.task}}" class="axis-entry-card axis-entry-card--saved">
            <text class="axis-entry-label">方向 {{index + 1}}</text>
            <text class="axis-entry-value">{{item.task}}</text>
          </view>
        </view>
      </block>

    </view>
  </view>
</view>
