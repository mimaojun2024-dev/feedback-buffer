<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" open-type="reLaunch" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack flow-page-stack">
      <view class="flow-hero">
        <text class="flow-title">只写眼前这一步</text>
        <text class="flow-copy">先把真正要碰的那一件事放到纸面上。</text>
      </view>

      <block wx:if="{{isEditingTask}}">
        <view class="flow-card">
          <text class="input-label">我现在要做的是</text>
          <textarea
            class="textarea textarea--compact"
            value="{{draftTask}}"
            placeholder="{{inputPlaceholders.startTask}}"
            data-placeholder-key="startTask"
            data-placeholder-text="比如：先把文档打开，写下第一段提纲"
            bindinput="handleInput"
            bindfocus="handleInputFocus"
            bindblur="handleInputBlur"
          />
          <button class="button-primary" bindtap="handleSubmit">只做两分钟</button>
        </view>
      </block>

      <block wx:else>
        <view class="summary start-task-summary">
          <text class="summary-label">我现在要做的是</text>
          <text class="summary-value">{{startTask}}</text>
          <button class="button-ghost micro-action-button start-task-edit" bindtap="handleEdit">修改</button>
        </view>
      </block>

      <view class="button-group start-action-group">
        <block wx:if="{{!isEditingTask}}">
          <button class="button-primary start-countdown-button" bindtap="handleStartCountdown">开始这两分钟</button>
        </block>
      </view>

      <view class="start-history-panel">
        <view class="start-history-head">
          <view class="start-history-copy">
            <text class="summary-label start-history-label">已经成功启动过</text>
          </view>
          <button
            wx:if="{{hasStartHistory}}"
            class="button-ghost micro-action-button start-history-manage"
            bindtap="handleToggleHistoryManagement"
          >
            {{isManagingHistory ? '完成' : '管理'}}
          </button>
        </view>

        <block wx:if="{{hasStartHistory}}">
          <view class="start-history-list">
            <view wx:for="{{startHistoryItems}}" wx:key="id" class="start-history-item">
              <view class="start-history-item-copy">
                <text class="start-history-task">{{item.task}}</text>
                <text class="start-history-time">{{item.completedAtLabel}}</text>
              </view>
              <button
                wx:if="{{isManagingHistory}}"
                class="button-ghost micro-action-button micro-action-button--danger start-history-delete"
                bindtap="handleDeleteHistoryItem"
                data-id="{{item.id}}"
              >
                删除
              </button>
            </view>
          </view>
        </block>

        <block wx:else>
          <text class="start-history-empty">每启动过一次，这里会多一条记录</text>
        </block>
      </view>
    </view>
  </view>
</view>
