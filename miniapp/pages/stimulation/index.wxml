<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
        <text class="eyebrow">状态入口</text>
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" class="pill-link">主页</navigator>
        <text class="badge">缓冲层</text>
      </view>
    </view>

    <view class="stack flow-page-stack">
      <view class="flow-hero">
        <text class="flow-title">我想来点刺激</text>
        <text class="flow-copy">先加一层缓冲，不让冲动直接接管。</text>
      </view>

      <view class="flow-list">
        <view class="flow-list-item">
          <text class="flow-list-mark">1</text>
          <text class="flow-list-title">先停 10 秒</text>
        </view>
        <view class="flow-list-item">
          <text class="flow-list-mark">2</text>
          <text class="flow-list-title">离开刺激入口</text>
        </view>
        <view class="flow-list-item">
          <text class="flow-list-mark">3</text>
          <text class="flow-list-title">回到今天主轴</text>
        </view>
      </view>

      <view class="button-group flow-action-row">
        <navigator url="/pages/axis-today/index" class="button-primary">回到主轴</navigator>
        <navigator url="/pages/home/index" class="button-secondary">回到主页</navigator>
      </view>
    </view>
  </view>
</view>
