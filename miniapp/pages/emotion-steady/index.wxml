<view class="page-shell">
  <view class="panel">
    <view class="top-bar">
      <view class="top-copy">
      </view>
      <view class="top-actions">
        <navigator url="/pages/home/index" open-type="reLaunch" class="pill-link">主页</navigator>
      </view>
    </view>

    <view class="stack flow-page-stack emotion-steady-stack">
      <view class="flow-hero flow-hero--center emotion-steady-hero">
        <text class="flow-title">缓一缓，别下坠</text>
        <text class="flow-copy">现在先不追问原因，把自己从最陡的地方扶住。</text>
      </view>

      <view class="card-list state-grid emotion-calm-grid">
        <view wx:for="{{stepRows}}" wx:for-item="row" wx:key="index" class="state-row">
          <view wx:for="{{row}}" wx:for-item="step" wx:key="id" class="state-cell">
            <view
              class="card card--interactive card--grid emotion-calm-card {{selectedStepId === step.id ? 'card--selected' : ''}}"
              bindtap="handleSelect"
              data-id="{{step.id}}"
            >
              <view class="state-card-head">
                <text class="state-card-emoji">{{step.emoji}}</text>
                <text class="state-card-name">{{step.title}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{selectedStepPrompt}}" class="emotion-steady-prompt-card" bindtap="handleOpenNextActions">
        <text class="emotion-steady-prompt-main">{{selectedStepPrompt}}</text>
        <text class="emotion-steady-prompt-hint">点一下，给自己留个出口</text>
      </view>

      <view wx:if="{{showNextActions}}" class="button-group flow-action-row emotion-steady-actions">
        <navigator url="/pages/tired-care/index" class="button-secondary button-preferred">先去休息</navigator>
        <navigator url="/pages/month-completed/index" class="button-secondary">看看已经完成</navigator>
      </view>
    </view>
  </view>
</view>
